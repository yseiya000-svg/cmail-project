# Node / Next.js
node_modules/
.next/
out/

# Electron build output
dist/
release/

# Logs
*.log
npm-debug.log*
yarn-debug.log*

# Local environment & secrets
.env
.env.local
.env.*.local

# OAuth credentials for "Desktop app" type Google OAuth client.
# These are baked into the Electron build via electron-builder (asar) so the
# packaged .exe can talk to Google, but they MUST NOT be committed to the
# public GitHub repo. The values live in .env.local on the dev machine and
# are mirrored into electron/credentials.js right before building.
electron/credentials.js
# Same file, post-monorepo path (apps/desktop layout):
apps/desktop/electron/credentials.js
# Belt-and-braces: any depth ending in electron/credentials.js
**/electron/credentials.js

# Local-only secret store (Google OAuth client ID/secret, Anthropic key etc.).
# Never commit — this directory exists only on Seiya's dev machine.
Client Codes/

# Claude Code per-project settings (machine-local agent state)
.claude/

# Per-install runtime settings (these live in userData in prod, but might
# show up at the project root during dev — never commit them)
cmail-settings.json
.nextauth-secret

# OS junk
.DS_Store
Thumbs.db

# Editor / IDE
.vscode/
.idea/
*.swp
*.swo

# TypeScript
*.tsbuildinfo
next-env.d.ts

# Misc
.cache/
.turbo/
coverage/
