{
  "name": "cmail-monorepo",
  "private": true,
  "version": "0.0.0",
  "description": "Cmail monorepo: Electron desktop app, Capacitor iOS app, and Vercel-hosted backend",
  "author": {
    "name": "Seiya Yamasaki",
    "email": "y.seiya000@gmail.com"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:desktop": "npm run dev --workspace cmail-desktop",
    "app:desktop": "npm run app --workspace cmail-desktop",
    "build:desktop": "npm run build:app --workspace cmail-desktop",
    "release:desktop": "npm run release --workspace cmail-desktop",
    "dev:mobile": "npm run dev --workspace cmail-mobile",
    "build:mobile": "npm run build --workspace cmail-mobile",
    "dev:backend": "npm run dev --workspace cmail-backend",
    "build:backend": "npm run build --workspace cmail-backend"
  }
}
