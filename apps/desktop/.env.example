# --- Google OAuth ---
# https://console.cloud.google.com/ で作成した OAuth 2.0 クライアントID/シークレットを設定
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- NextAuth ---
# 空のままでもOK：Electron 起動時に %APPDATA%\Cmail\.nextauth-secret に
# ランダム値が自動生成されます。Web版を別途デプロイする場合のみ手動で設定してください。
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# --- Claude (Anthropic) ---
# 配布版では設定画面からユーザー自身が入力します（BYOK 方式）。
# 開発時のフォールバックとしてここに自分のキーを置いてもOK。
ANTHROPIC_API_KEY=

# --- Obsidian (オプション) ---
# デフォルトの Cmail フォルダパスを ${OBSIDIAN_VAULT_PATH}/Main Brain/Cmail に組み立てるための
# vault ルートパス。設定画面から任意のパスに上書き可能。
OBSIDIAN_VAULT_PATH=
