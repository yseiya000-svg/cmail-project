# Google OAuth (Google Cloud Console で取得)
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# NextAuth シークレット (openssl rand -base64 32 で生成)
NEXTAUTH_SECRET=your_nextauth_secret_here
NEXTAUTH_URL=http://localhost:3000

# Claude API (https://console.anthropic.com で取得)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Obsidian Vault パス (学習データ・プロフィール参照)
OBSIDIAN_VAULT_PATH=E:\iCloudDrive\iCloud~md~obsidian
